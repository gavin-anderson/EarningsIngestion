# Copy this file to .env and fill in values for your environment.
# .env is gitignored; .env.example is committed as a template.
# Existing shell env vars take precedence over .env values.

# --- Hyperliquid endpoints ---
# Direct mainnet (works only from geo-allowed locations):
#   HL_REST_URL=https://api.hyperliquid.xyz/info
#   HL_WS_URL=wss://api.hyperliquid.xyz/ws
# Route through your geo proxy instead (both REST and WS):
HL_REST_URL=https://YOUR_PROXY_HOST/info
HL_WS_URL=wss://YOUR_PROXY_HOST/ws

# Shared secret sent as the X-Proxy-Key header to authenticate with the
# edge proxy. Leave empty for direct Hyperliquid access (no proxy auth).
HL_PROXY_KEY=

# --- ClickHouse (defaults match docker-compose.yml) ---
CH_ADDR=localhost:9000
CH_DATABASE=hl
CH_USERNAME=default
CH_PASSWORD=

# --- Logging ---
# One of: debug, info, warn, error
LOG_LEVEL=info
